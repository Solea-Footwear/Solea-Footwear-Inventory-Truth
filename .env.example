# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/inventory_db
# Alternative individual components if DATABASE_URL is not provided:
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=inventory_db
# DB_USER=postgres
# DB_PASSWORD=your_password

# eBay API Configuration
EBAY_APP_ID=your_ebay_app_id
EBAY_CERT_ID=your_ebay_cert_id
EBAY_DEV_ID=your_ebay_dev_id
EBAY_AUTH_TOKEN=your_legacy_auth_token
EBAY_ENVIRONMENT=production  # or 'sandbox' for testing

# eBay OAuth 2.0 Configuration (Phase 3 migration path — full flow in src.integrations.ebay.ebay_oauth)
EBAY_OAUTH_TOKEN=your_oauth_access_token_here
EBAY_OAUTH_REFRESH_TOKEN=your_oauth_refresh_token_here
EBAY_OAUTH_REDIRECT_URI=http://localhost:9500/oauth/ebay/callback
EBAY_OAUTH_SCOPES=https://api.ebay.com/oauth/api_scope https://api.ebay.com/oauth/api_scope/sell.inventory https://api.ebay.com/oauth/api_scope/sell.account https://api.ebay.com/oauth/api_scope/sell.fulfillment
# Fernet key — generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
EBAY_TOKEN_ENCRYPTION_KEY=replace-with-fernet-key

# AI parser (Anthropic Claude) — used by Mercari/Poshmark cross-listing item-specifics extraction
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Gmail API Configuration
GMAIL_TOKEN_PATH=./gmail_token.pickle  # Path where Gmail token will be stored

# Secret Key for Flask
SECRET_KEY=your_secret_key_here

# Scheduler Configuration
AUTO_SYNC_ENABLED=true
SYNC_INTERVAL_MINUTES=60
AUTO_DELIST_ENABLED=true
AUTO_CROSSLIST_ENABLED=false
EMAIL_CHECK_INTERVAL_MINUTES=3
CROSSLIST_CHECK_INTERVAL_MINUTES=60

# Return Tracking Configuration
RETURN_CHECK_INTERVAL_HOURS=24
EBAY_RETURNS_GMAIL_LABEL=EBAY_RETURNS_TRACKING
RETURN_PROCESSING_ENABLED=true

# API Configuration
API_PORT=9500
# Inside Docker the container binds 0.0.0.0; the host-side mapping in docker-compose.yml
# restricts external access to 127.0.0.1. For non-Docker local dev, use 127.0.0.1 here.
API_HOST=127.0.0.1

# eBay Sync Settings
AUTO_SYNC_EBAY_LISTINGS=true
AUTO_SYNC_SOLD_ITEMS=true

# pgAdmin Configuration — REQUIRED. docker-compose.yml fails fast if either is missing.
PGADMIN_EMAIL=replace-me@example.com
PGADMIN_PASSWORD=replace-with-strong-password

# Selenium (Mercari/Poshmark listers)
SELENIUM_HEADLESS=true
